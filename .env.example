# VibePlay – Riko environment
# Copy to .env and adjust. Only EXPO_PUBLIC_* vars are exposed to the JS bundle.

EXPO_PUBLIC_APP_NAME=VibePlay – Riko
EXPO_PUBLIC_ENV=development

# Used by app.config.ts / EAS. Set this in your EAS project (eas secret) for CI builds.
EAS_PROJECT_ID=00000000-0000-0000-0000-000000000000
